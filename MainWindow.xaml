<ui:FluentWindow x:Class="ColorCodePicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Color Code Picker" SizeToContent="Height" Width="700"
        WindowBackdropType="Auto"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Munsell Color Picker" VerticalAlignment="Top" Panel.ZIndex="1" />
        
        <!-- 메인 컨텐츠 영역 -->
        <ScrollViewer Grid.Row="0" Margin="0,50,0,0" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,0,20,10">
                <!-- 분할 영역 -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="6*" />
                    </Grid.ColumnDefinitions>

                <!-- 왼쪽: 입력 및 스포이드 -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <ui:Button x:Name="EyedropperButton" Content="스포이드로 색상 추출" Icon="{ui:SymbolIcon Color24}" HorizontalAlignment="Stretch" Margin="0,0,0,20" Click="EyedropperButton_Click" Appearance="Primary" />

                    <TextBlock Text="수동 입력" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="HEX" Margin="0,0,0,5"/>
                    <ui:TextBox x:Name="HexInputTextBox" PlaceholderText="#FFFFFF" Margin="0,0,0,10" TextChanged="InputTextBox_TextChanged" />
                    
                    <TextBlock Text="RGB" Margin="0,0,0,5"/>
                    <ui:TextBox x:Name="RgbInputTextBox" PlaceholderText="255, 255, 255" TextChanged="InputTextBox_TextChanged" Margin="0,0,0,10" />

                    <TextBlock Text="Munsell" Margin="0,0,0,5"/>
                    <ui:TextBox x:Name="MunsellInputTextBox" PlaceholderText="5.0R 4.0/10.0" TextChanged="InputTextBox_TextChanged" Margin="0,0,0,10" />

                    <TextBlock Text="RAL Classic" Margin="0,0,0,5"/>
                    <ui:TextBox x:Name="RalInputTextBox" PlaceholderText="RAL 3020" TextChanged="InputTextBox_TextChanged" Margin="0,0,0,10" />

                    <TextBlock Text="CIE XYZ" Margin="0,0,0,5" Visibility="Collapsed"/>
                    <ui:TextBox x:Name="XyzInputTextBox" PlaceholderText="69.1, 72.7, 55.3" TextChanged="InputTextBox_TextChanged" Margin="0,0,0,10" Visibility="Collapsed"/>

                    <TextBlock Text="CIE L*a*b*" Margin="0,0,0,5" Visibility="Collapsed"/>
                    <ui:TextBox x:Name="LabInputTextBox" PlaceholderText="89.1, -0.4, 20.4" TextChanged="InputTextBox_TextChanged" Margin="0,0,0,10" Visibility="Collapsed"/>

                    <TextBlock Text="CMYK" Margin="0,0,0,5" Visibility="Collapsed"/>
                    <ui:TextBox x:Name="CmykInputTextBox" PlaceholderText="0, 7, 23, 0" TextChanged="InputTextBox_TextChanged" Margin="0,0,0,10" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#FF333333" Margin="5,0,5,0" />

                <!-- 오른쪽: 결과 출력 -->
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <ui:CardControl Margin="0,0,0,10">
                        <ui:CardControl.Header>
                            <TextBlock Text="RGB (Red, Green, Blue)" FontWeight="Bold" />
                        </ui:CardControl.Header>
                        <Border x:Name="RgbColorPreview" CornerRadius="4" Padding="10,5" BorderBrush="#555" BorderThickness="1">
                            <TextBox x:Name="ResultRgbText" Text="-" FontSize="16" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,10">
                        <ui:CardControl.Header>
                            <TextBlock Text="HEX (Web Color)" FontWeight="Bold" />
                        </ui:CardControl.Header>
                        <Border x:Name="HexColorPreview" CornerRadius="4" Padding="10,5" BorderBrush="#555" BorderThickness="1">
                            <TextBox x:Name="ResultHexText" Text="-" FontSize="16" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,10">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="Munsell" FontWeight="Bold" />
                                <TextBlock Text="근사치로 계산" FontSize="11" Foreground="Gray" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <Border x:Name="MunsellColorPreview" CornerRadius="4" Padding="10,5" BorderBrush="#555" BorderThickness="1">
                            <TextBox x:Name="ResultMunsellText" Text="-" FontSize="16" FontWeight="Bold" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,10">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="RAL Classic" FontWeight="Bold" />
                                <TextBlock x:Name="RalDifferenceText" Text="가장 비슷한 색" FontSize="11" Foreground="Gray" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <Border x:Name="RalColorPreview" CornerRadius="4" Padding="10,5" BorderBrush="#555" BorderThickness="1">
                            <TextBox x:Name="ResultRalText" Text="-" FontSize="16" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,10" Visibility="Collapsed">
                        <ui:CardControl.Header>
                            <TextBlock Text="CIE XYZ (Illuminant D65)" FontWeight="Bold" />
                        </ui:CardControl.Header>
                        <TextBox x:Name="ResultXyzText" Text="-" FontSize="16" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" />
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,10" Visibility="Collapsed">
                        <ui:CardControl.Header>
                            <TextBlock Text="CIE L*a*b* (Illuminant D65)" FontWeight="Bold" />
                        </ui:CardControl.Header>
                        <TextBox x:Name="ResultLabText" Text="-" FontSize="16" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" />
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,10" Visibility="Collapsed">
                        <ui:CardControl.Header>
                            <TextBlock Text="CMYK (Standard Formula)" FontWeight="Bold" />
                        </ui:CardControl.Header>
                        <TextBox x:Name="ResultCmykText" Text="-" FontSize="16" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" />
                    </ui:CardControl>
                </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- 개발자에게 커피 사주기 UI 통합 배치 (가로 확장) -->
        <Border Grid.Row="1" Background="#FF252525" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="8" Padding="20" Margin="20,0,20,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 텍스트 영역 (왼쪽) -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                            <TextBlock Text="☕ 개발자에게 커피 사주기" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
                            <TextBlock Text="유용하게 사용하고 계신가요?&#x0a;만족하셨다면 시원한 커피 한 잔 선물해주세요!" FontSize="13" Foreground="#FFAAAAAA" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>

                        <!-- QR 코드 영역 (오른쪽) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 카카오페이 -->
                            <StackPanel Margin="0,0,15,0" HorizontalAlignment="Center">
                                <TextBlock Text="카카오페이" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <Border CornerRadius="8" Background="White" Padding="5">
                                    <Image Source="pack://application:,,,/Assets/kakao_qr.png" Width="90" Height="90" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>

                            <!-- 토스 -->
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="토스 (Toss)" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <Border CornerRadius="8" Background="White" Padding="5">
                                    <Image Source="pack://application:,,,/Assets/toss_qr.png" Width="90" Height="90" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
